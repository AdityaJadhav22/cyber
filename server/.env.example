PORT=5000
# Paste your MongoDB Atlas connection string here.
# Example format: mongodb+srv://<username>:<password>@<cluster-url>/<dbName>?retryWrites=true&w=majority
MONGO_URI=your_mongodb_atlas_connection_string
# .env keeps secrets out of code and out of git history.
JWT_SECRET=replace_with_long_random_secret
JWT_EXPIRES_IN=1h
SESSION_TIMEOUT_MS=900000
BULK_ACCESS_THRESHOLD=30
CLIENT_ORIGIN=http://localhost:5173
DEMO_SHOW_RESET_TOKEN=true
